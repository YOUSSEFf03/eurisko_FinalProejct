<html>
  <head>
    <meta charset='UTF-8' />
    <style>
      body {
        font-family: Arial, sans-serif;
        background: #f4f4f4;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        background: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }
      .header {
        background: #1a1a2e;
        padding: 30px;
        text-align: center;
      }
      .header h1 {
        color: #e94560;
        margin: 0;
        font-size: 24px;
      }
      .body {
        padding: 40px 30px;
      }
      .body p {
        color: #333;
        font-size: 15px;
        line-height: 1.6;
      }
      .amount-box {
        background: #e8f5e9;
        border-left: 4px solid #2e7d32;
        border-radius: 4px;
        padding: 20px 25px;
        margin: 25px 0;
      }
      .amount-box .label {
        color: #666;
        font-size: 13px;
        margin: 0;
      }
      .amount-box .value {
        color: #2e7d32;
        font-size: 28px;
        font-weight: bold;
        margin: 5px 0 0;
      }
      .details {
        background: #f9f9f9;
        border-radius: 6px;
        padding: 15px 20px;
        margin: 20px 0;
      }
      .details table {
        width: 100%;
        border-collapse: collapse;
      }
      .details td {
        padding: 8px 0;
        color: #555;
        font-size: 14px;
      }
      .details td:last-child {
        text-align: right;
        font-weight: bold;
        color: #333;
      }
      .footer {
        background: #f4f4f4;
        padding: 20px;
        text-align: center;
        color: #aaa;
        font-size: 12px;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='header'><h1>Stock Market Platform</h1></div>
      <div class='body'>
        <p>Hi <strong>{{name}}</strong>,</p>
        <p>Your wallet has been successfully credited.</p>
        <div class='amount-box'>
          <p class='label'>Amount Credited</p>
          <p class='value'>+{{currency}} {{amount}}</p>
        </div>
        <div class='details'>
          <table>
            <tr><td>New Balance</td><td>{{currency}} {{newBalance}}</td></tr>
            <tr><td>Transaction ID</td><td>{{transactionId}}</td></tr>
          </table>
        </div>
        <p>Your funds are now available for trading.</p>
      </div>
      <div class='footer'>© 2026 Stock Market Platform. All rights reserved.</div>
    </div>
  </body>
</html>